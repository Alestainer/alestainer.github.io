---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: {
    '@type': 'Person',
    name: 'Anton Nikolaev',
    url: 'https://alestainer.github.io',
  },
  serviceType: 'AI & Machine Learning Consulting',
  areaServed: 'Worldwide',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'AI Engineering Services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Agentic Systems Design & Development',
          description: 'Design and build LLM-powered autonomous AI agents for complex workflow automation.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'AI Product Development',
          description: 'LLM-powered products end-to-end: architecture, development, deployment, ready for real users.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'MLOps & AIOps',
          description: 'Production ML and LLMOps pipelines, model fine-tuning, monitoring, and inference optimization.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Search & Retrieval Systems',
          description: 'Production search engines, RAG pipelines, vector databases, and NLP-powered retrieval.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Computer Vision',
          description: 'Custom deep learning vision models for detection, segmentation, and visual understanding.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'AI Strategy & Technical Consulting',
          description: 'Senior-level GenAI strategy, AI governance, LLM evaluation, and enterprise AI transformation.',
        },
      },
    ],
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://alestainer.github.io' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://alestainer.github.io/services' },
  ],
};

const services = [
  {
    title: 'Agentic Systems Design & Development',
    description: 'I build LLM-powered agents that plan, reason, use tools, and execute multi-step workflows. Internal tools, research assistants, customer-facing agents. Reliable and observable.',
    capabilities: [
      'Multi-agent orchestration and coordination',
      'LLM tool use and API integration',
      'Planning and reasoning architectures (ReAct, chain-of-thought)',
      'Human-in-the-loop workflows and prompt engineering',
      'Agent evaluation, testing, and AgentOps',
      'Game-theoretic incentive alignment',
      'Reward modeling and evaluation guardrails',
    ],
  },
  {
    title: 'AI Product Development',
    description: 'LLM-powered products end-to-end: architecture, backend, frontend, deployment. I ship the whole thing, ready for users.',
    capabilities: [
      'End-to-end GenAI product architecture',
      'Rapid prototyping and MVP development',
      'LLM integration and prompt engineering',
      'API design, NLP pipelines, and third-party integrations',
      'Production deployment and scaling',
    ],
  },
  {
    title: 'MLOps & AIOps',
    description: 'Infrastructure to train, fine-tune, deploy, and monitor ML models and LLMs at scale. Reproducibility and observability included.',
    capabilities: [
      'CI/CD for ML and LLMOps pipelines',
      'Model fine-tuning, versioning, and registry',
      'Automated retraining and drift detection',
      'Inference optimization and GPU cost management',
      'Infrastructure as code for ML',
    ],
  },
  {
    title: 'Search & Retrieval Systems',
    description: 'Production search engines serving millions of users, and RAG (Retrieval-Augmented Generation) pipelines that ground LLMs in your data. I\'ve done both.',
    capabilities: [
      'Production search systems at scale',
      'Search relevance tuning and A/B testing',
      'RAG pipeline architecture and optimization',
      'Vector database design and embedding model selection',
      'Hybrid search (semantic + keyword) and reranking',
      'NLP-powered document ingestion and chunking',
    ],
  },
  {
    title: 'Computer Vision',
    description: 'Custom deep learning vision models for your specific use case. Full lifecycle: data strategy, annotation, training, optimization, edge deployment.',
    capabilities: [
      'Object detection and instance segmentation',
      'Image classification and visual search',
      'Video analysis and tracking',
      'Deep learning model optimization and edge deployment',
      'Synthetic data generation',
    ],
  },
  {
    title: 'AI Strategy & Technical Consulting',
    description: 'GenAI strategy, vendor evaluation, architecture review, governance. A decade of shipping ML systems across industries.',
    capabilities: [
      'GenAI strategy and AI readiness assessment',
      'LLM evaluation, vendor and model selection',
      'Enterprise AI architecture design and review',
      'AI governance and risk frameworks',
      'Causal inference and experimentation design',
      'Proof-of-concept development and team capability building',
    ],
  },
];
---

<BaseLayout
  title="AI Engineering Services — Agentic AI, LLM Development, MLOps, RAG | Anton Nikolaev"
  description="Expert AI consulting: agentic systems, generative AI product development, LLM fine-tuning, MLOps, RAG pipelines, NLP, computer vision, and GenAI strategy. Book a free consultation."
  schemas={[serviceSchema, breadcrumbSchema]}
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-12 sm:pt-24 sm:pb-16">
    <nav class="text-sm text-text-muted mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-text">Services</span>
    </nav>

    <h1 class="text-4xl sm:text-5xl font-bold text-text mb-6">
      AI Engineering Services
    </h1>
    <p class="text-lg text-text-muted leading-relaxed max-w-2xl mb-16">
      I help teams build, deploy, and operate AI systems, from early-stage prototypes to production-grade infrastructure. Every engagement starts with understanding your problem.
    </p>

    <div class="space-y-12">
      {services.map((service) => (
        <div class="bg-surface rounded-xl p-6 sm:p-8 border border-border">
          <h2 class="text-2xl font-bold text-text mb-3">{service.title}</h2>
          <p class="text-text-muted leading-relaxed mb-5">{service.description}</p>
          <ul class="space-y-2">
            {service.capabilities.map((cap) => (
              <li class="flex items-start gap-2 text-sm text-text-muted">
                <span class="text-primary mt-0.5 shrink-0">&#x2713;</span>
                {cap}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 text-center">
    <h2 class="text-3xl font-bold text-text mb-4">Let's discuss your project</h2>
    <p class="text-text-muted mb-8 max-w-xl mx-auto">
      Book a free 30-minute consultation. I'll listen to your challenge and share honest feedback on whether and how AI can help.
    </p>
    <a
      href="/book"
      class="inline-flex items-center justify-center bg-primary text-white px-8 py-3 rounded-lg font-medium hover:bg-primary-dark transition-colors"
    >
      Book a Free Call
    </a>
  </section>
</BaseLayout>
